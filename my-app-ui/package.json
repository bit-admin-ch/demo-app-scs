{
  "name": "my-app-ui",
  "version": "1.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build --base-href /my-app/",
    "build-dev": "ng build -c development --base-href /my-app/",
    "build-prod": "ng build -c production --base-href /my-app/",
    "test": "ng test",
    "test:ci": "ng test --watch=false --silent",
    "lint": "ng lint",
    "lint-fix": "ng lint --fix",
    "prettier": "./node_modules/.bin/prettier --write **/{*.ts,*.html,*.scss,*.json,*.js}",
    "format": "npm run lint -- --fix && npm run prettier"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.17",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "20.3.17",
    "@angular/compiler": "20.3.17",
    "@angular/core": "20.3.17",
    "@angular/forms": "20.3.17",
    "@angular/platform-browser": "20.3.17",
    "@angular/platform-browser-dynamic": "20.3.17",
    "@angular/router": "20.3.17",
    "@ngrx/store-devtools": "^20.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@popperjs/core": "^2.0.0",
    "@quadrel-enterprise-ui/auth": "^20.1.3",
    "@quadrel-enterprise-ui/browser-check": "^20.0.1",
    "@quadrel-enterprise-ui/framework": "^20.4.1",
    "@quadrel-enterprise-ui/language": "^20.0.1",
    "ngx-translate-multi-http-loader": "^3.0.0",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.3",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^20.0.0",
    "@angular-devkit/schematics": "20.3.19",
    "@angular-eslint/builder": "18.2.0",
    "@angular-eslint/eslint-plugin": "18.4.3",
    "@angular-eslint/eslint-plugin-template": "18.2.0",
    "@angular-eslint/template-parser": "18.4.3",
    "@angular/build": "^20.3.19",
    "@angular/cli": "~20.3.19",
    "@angular/compiler-cli": "20.3.17",
    "@types/jest": "^29.5.6",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "8.32.1",
    "@typescript-eslint/parser": "8.32.1",
    "ajv": "^8.0.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "^5.4.0",
    "jest": "^29.7.0",
    "jest-sonar-reporter": "2.0.0",
    "ng-mocks": "^14.13.1",
    "prettier": "3.3.2",
    "typescript": "~5.8.3"
  },
  "jestSonar": {
    "reportPath": "./coverage/sonarQube",
    "reportFile": "sqr.xml",
    "indent": 4,
    "sonar56x": true
  },
  "lint-staged": {
    "**/*.{js,ts,md,html,json}": [
      "prettier --write"
    ],
    "**/*.ts": [
      "ng-lint-staged lint --fix --"
    ]
  }
}
